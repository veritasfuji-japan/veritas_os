{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "veritas://policies/action-contracts/schema.json",
  "title": "VERITAS Action Class Contract Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "domain",
    "action_class",
    "description",
    "declared_intent",
    "allowed_scope",
    "prohibited_scope",
    "authority_sources",
    "required_evidence",
    "evidence_freshness",
    "irreversibility",
    "human_approval_rules",
    "refusal_conditions",
    "escalation_conditions",
    "default_failure_mode",
    "metadata"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "action_class": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "declared_intent": {"type": "string", "minLength": 1},
    "allowed_scope": {
      "type": "array",
      "items": {"type": "string"}
    },
    "prohibited_scope": {
      "type": "array",
      "items": {"type": "string"}
    },
    "authority_sources": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_evidence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": true
    },
    "irreversibility": {
      "type": "object",
      "additionalProperties": true
    },
    "human_approval_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "refusal_conditions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "escalation_conditions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "default_failure_mode": {
      "type": "string",
      "enum": ["fail_closed", "deny", "escalate"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "regulated": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "regulated": {"const": true}
            },
            "required": ["regulated"]
          }
        }
      },
      "then": {
        "properties": {
          "allowed_scope": {"minItems": 1},
          "prohibited_scope": {"minItems": 1}
        }
      }
    }
  ]
}
